  "verification_instructions": {
    "step1": "Download aerosys-jwks.json — contains all public keys",
    "step2": "For each .jwt file: split by \".\" → header.payload.signature",
    "step3": "Base64url-decode header → extract kid field",
    "step4": "Find matching key in JWK Set by kid",
    "step5": "Verify RS256 signature: crypto.verify(\"sha256\", header.payload, publicKey, signature)",
    "step6": "Base64url-decode payload → confirm all document hashes match your local copies",
    "step7": "Confirm iss, aud, iat, exp fields match expected values",
    "node_example": "\nconst jwt = require('fs').readFileSync('AEROSYS-DER-ATTESTATION.jwt','utf8');\nconst [h,p,s] = jwt.split('.');\nconst jwks = JSON.parse(require('fs').readFileSync('aerosys-jwks.json'));\nconst header = JSON.parse(Buffer.from(h,'base64url'));\nconst key = jwks.keys.find(k => k.kid === header.kid);\nconst pub = require('crypto').createPublicKey({ key, format:'jwk' });\nconst ok = require('crypto').verify('sha256',\n  Buffer.from(h+'.'+p), { key:pub, padding:require('crypto').constants.RSA_PKCS1_PADDING },\n  Buffer.from(s,'base64url'));\nconsole.log('DER signature valid:', ok);\nconsole.log('Payload:', JSON.parse(Buffer.from(p,'base64url')));"
  }
